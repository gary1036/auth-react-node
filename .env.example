# Application
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
WEB_ORIGIN=http://localhost:5173

# Database
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_DB=auth_db
DATABASE_URL=postgresql://auth:auth@db:5432/auth_db?schema=public

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-min-32
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-min-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OIDC (create OAuth client in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback
OIDC_FRONTEND_CALLBACK=http://localhost:5173/oauth/callback

# OpenWeatherMap (https://home.openweathermap.org/api_keys)
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
